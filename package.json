{
  "name": "polyv-live",
  "version": "1.0.0",
  "private": true,
  "description": "PolyV Live Streaming Monorepo - SDK and CLI",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:coverage": "pnpm --filter polyv-live-cli test:coverage && pnpm --filter polyv-live-api-sdk test:coverage",
    "test:integration": "pnpm --filter polyv-live-cli test:integration",
    "test:cli:coverage": "pnpm --filter polyv-live-cli test:coverage",
    "test:sdk:coverage": "pnpm --filter polyv-live-api-sdk test:coverage",
    "coverage:badge": "node scripts/update-coverage-badge.mjs",
    "skill:check": "node scripts/check-skill-regression.mjs",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "release:cli": "pnpm --filter polyv-live-cli publish",
    "release:cli:dry": "pnpm --filter polyv-live-cli pack --dry-run",
    "changelog": "pnpm --filter polyv-live-cli changelog",
    "changelog:update": "pnpm --filter polyv-live-cli changelog:update",
    "release:cli:patch": "./scripts/release.sh cli patch",
    "release:cli:minor": "./scripts/release.sh cli minor",
    "release:cli:major": "./scripts/release.sh cli major",
    "release:sdk:patch": "./scripts/release.sh sdk patch",
    "release:sdk:minor": "./scripts/release.sh sdk minor",
    "release:sdk:major": "./scripts/release.sh sdk major",
    "publish:sdk": "cd packages/sdk && npm version patch && pnpm publish --no-git-checks"
  },
  "keywords": [
    "polyv",
    "live-streaming",
    "monorepo"
  ],
  "author": "PolyV Team",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@rollup/rollup-darwin-arm64": "^4.59.1"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
