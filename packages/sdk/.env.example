# PolyV API Credentials
# Get these from PolyV Live Dashboard -> Settings -> API Settings

POLYV_APP_ID=your_app_id_here
POLYV_APP_SECRET=your_app_secret_here

# Optional: Your PolyV User ID (used for channel operations)
POLYV_USER_ID=your_user_id_here

# Optional: Channel ID for integration tests (Auth/Doc/Multimedia APIs)
POLYV_CHANNEL_ID=your_channel_id_here

# Optional: Child account user ID for child-channel read-only integration checks
POLYV_CHILD_USER_ID=your_child_user_id_here

# Optional: explicitly enable integration tests that write and clean up test data
POLYV_RUN_WRITE_INTEGRATION=false
